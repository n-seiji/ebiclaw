FROM alpine:3.21

ARG TARGETPLATFORM

RUN apk add --no-cache ca-certificates tzdata

COPY $TARGETPLATFORM/ebiclaw /usr/local/bin/ebiclaw
COPY $TARGETPLATFORM/ebiclaw-launcher /usr/local/bin/ebiclaw-launcher
COPY $TARGETPLATFORM/ebiclaw-launcher-tui /usr/local/bin/ebiclaw-launcher-tui

ENTRYPOINT ["ebiclaw-launcher"]
CMD ["-console", "-public", "-no-browser"]
